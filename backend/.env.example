# Copy this file to .env and fill your local values

# Option A (recommended): full SQLAlchemy URL
DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@127.0.0.1:3306/rhino_gene?charset=utf8mb4

# Option B: component values (used only if DATABASE_URL is omitted)
MYSQL_USER=root
MYSQL_PASSWORD=YOUR_PASSWORD
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=rhino_gene
